  // ========================= 	GET ALL NOTES  ==========================
 
exports.getAllNotes= async(req,res)=>
 {
    try{
         {
          const request = await pool.query("SELECT * FROM NOTES"); 
          res.json(request.rows);
         }
       }

     catch (err){
                 console.error(err);
                 res.status(500).json({message : "ERROR READING notes"});
       }
};
